rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTask() {
      let data = request.resource.data;
      return hasRequiredFields(['id', 'name', 'deadline', 'estimatedDuration', 'priority', 'isImportant', 'isCompleted', 'createdAt', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 500 &&
             data.deadline is number &&
             data.estimatedDuration is number && data.estimatedDuration >= 0 &&
             data.priority in ['CRITICAL', 'HIGH', 'MEDIUM', 'LOW'] &&
             data.isImportant is bool &&
             data.isCompleted is bool &&
             data.createdAt is number &&
             data.uid == request.auth.uid;
    }

    function isValidGoal() {
      let data = request.resource.data;
      return hasRequiredFields(['id', 'name', 'color', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.color is string && data.color.size() <= 50 &&
             data.uid == request.auth.uid;
    }

    function isValidUserSettings() {
      let data = request.resource.data;
      return hasRequiredFields(['uid']) &&
             data.uid == request.auth.uid &&
             (!('customOrder' in data) || data.customOrder is list) &&
             (!('taskProgress' in data) || data.taskProgress is map);
    }

    function isValidProfile() {
      let data = request.resource.data;
      return hasRequiredFields(['uid']) &&
             data.uid == request.auth.uid &&
             (!('username' in data) || (data.username is string && data.username.size() <= 50)) &&
             (!('hasCompletedOnboarding' in data) || data.hasCompletedOnboarding is bool);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTask() && uidUnchanged();
        allow update: if isOwner(userId) && isValidTask() && uidNotModified();
        allow delete: if isOwner(userId);
      }
      
      match /goals/{goalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidGoal() && uidUnchanged();
        allow update: if isOwner(userId) && isValidGoal() && uidNotModified();
        allow delete: if isOwner(userId);
      }
      
      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidUserSettings() && uidUnchanged();
        allow update: if isOwner(userId) && isValidUserSettings() && uidNotModified();
        allow delete: if isOwner(userId);
      }

      match /profile/{document=**} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProfile() && uidUnchanged();
        allow update: if isOwner(userId) && isValidProfile() && uidNotModified();
        allow delete: if isOwner(userId);
      }
    }
  }
}
